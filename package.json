{
  "name": "strapi-export-import-excel",
  "version": "1.0.2",
  "description": "A Strapi v5 plugin for exporting and importing collection data as Excel, with live preview and per-collection field configuration.",
  "license": "MIT",
  "author": "Assawin Chittanandha <chittanandhaassawin@gmail.com>",
  "homepage": "https://github.com/mello-x/strapi-export-import-excel#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mello-x/strapi-export-import-excel.git"
  },
  "keywords": [
    "strapi",
    "strapi-plugin",
    "excel",
    "export",
    "import",
    "xlsx",
    "strapi-v5"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@strapi/design-system": "2.0.0-rc.30",
    "@strapi/icons": "2.0.0-rc.30",
    "@strapi/sdk-plugin": "6.0.1",
    "@strapi/strapi": "5.40.0",
    "@strapi/typescript-utils": "5.40.0",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "husky": "9.1.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-intl": "6.8.9",
    "react-router-dom": "6.30.3",
    "styled-components": "6.3.12",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi-export-import-excel",
    "displayName": "Export / Import Excel",
    "description": "A Strapi v5 plugin for exporting and importing collection data as Excel, with live preview and per-collection field configuration."
  },
  "dependencies": {
    "exceljs": "4.4.0"
  }
}
